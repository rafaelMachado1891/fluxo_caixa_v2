TARGET_DATABASE_URL="postgresql+psycopg2://postgres:sua_senha@db.seu-projeto.supabase.co:5432/postgres?sslmode=require"
SCHEMA=public

# Formato legado. Use apenas se nao quiser informar TARGET_DATABASE_URL.
# HOST=fluxo_de_caixa
# USER=administrador
# PASSWORD=sua_senha
# PORT=5432
# DBNAME=fluxo_db
# TARGET_DB_SSLMODE=require

# Formato recomendado para o banco de origem SQL Server.
SOURCE_DB_HOST=servidor_origem
SOURCE_DB_USER=usuario_origem
SOURCE_DB_PASSWORD=sua_senha_origem
SOURCE_DB_NAME=banco_origem
SOURCE_DB_DRIVER=ODBC Driver 17 for SQL Server

# Opcional: se preferir informar a URL completa manualmente.
# DATABASE_URL="mssql+pyodbc://usuario:senha@servidor/banco?driver=ODBC+Driver+17+for+SQL+Server"

RAW_SCHEMA=raw
SQL_DIR=src/data/sql
WRITE_MODE=replace
